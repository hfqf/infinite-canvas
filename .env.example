# 管理员账号，首次启动会自动创建。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=infinite-canvas

# JWT 登录密钥和过期时间，正式部署请修改 JWT_SECRET。
JWT_SECRET=infinite-canvas
JWT_EXPIRE_HOURS=168

# 后端默认监听 8080，如需本地开发修改端口再取消注释。
# Docker 镜像内前端固定监听 3000，避免覆盖前端 PORT。
# PORT=8080

# 公开访问地址，用于把本地上传的 Seedance 参考图/视频暴露给火山方舟拉取。
# 线上部署时填写站点根地址，例如：https://your-domain.example.com
PUBLIC_BASE_URL=https://www.haotushow.com

# 微信支付网页端充值。开启后，网页右上角“充值”会创建 Native 扫码支付订单。
WECHAT_PAY_ENABLED=true
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_SECRET=
WECHAT_PAY_KEY_PATH=data/wxpay/1483076642_cert/apiclient_key.pem
WECHAT_PAY_CERTIFICATE_SERIAL_NO=
WECHAT_PAY_PUBLIC_KEY_ID=
# WECHAT_PAY_PUBLIC_KEY_PATH=/path/to/wechatpay_public_key.pem
WECHAT_PAY_SKIP_NOTIFY_VERIFY=true
WECHAT_PAY_NOTIFY_URL=https://www.haotushow.com/api/recharge/wechat/notify

# 注册邮箱验证码。默认 noop 用于本地调试，会在接口返回 debugCode；生产设置为 smtp 后通过邮件发送。
FIGO_VERIFICATION_PROVIDER=noop
FIGO_SMTP_HOST=smtpdm.aliyun.com
FIGO_SMTP_PORT=25
FIGO_SMTP_USERNAME=
FIGO_SMTP_PASSWORD=
FIGO_SMTP_FROM=

# 图片节点“转矢量”使用 png2svg-clean-node。Docker 镜像已内置；本地开发需先在 png2svg-clean-node 下执行 npm install，并安装 ImageMagick。
PNG2SVG_CLEAN_TOOL_DIR=png2svg-clean-node
PNG2SVG_CLEAN_NODE_PATH=node
PNG2SVG_CLEAN_PROFILE=generic-clean-logo
PNG2SVG_CLEAN_TIMEOUT_SEC=90
IMAGE_MAGICK_PATH=magick

# 前端开发代理默认使用 http://127.0.0.1:8080，如后端开发端口不同，启动前端时可单独设置 API_BASE_URL。
# API_BASE_URL=http://127.0.0.1:8080
NEXT_PUBLIC_DOC_URL=https://docs.canvas.best

# 数据库配置，默认使用 MySQL。目标库不存在时会尝试自动创建，账号需有 CREATE 权限。
DATABASE_DRIVER=mysql
DATABASE_DSN=user:password@tcp(127.0.0.1:3306)/infinite_canvas?charset=utf8mb4&parseTime=True&loc=Local

# 图片上传存储，画布生成图片会上传到阿里云 OSS 并使用公网链接。
FIGO_STORAGE_DRIVER=oss
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET=haotushow3
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_PUBLIC_BASE_URL=https://oss.haotushow.com
