{
  "name": "bls-clean-ribbon",
  "preprocess": {
    "alphaOff": true,
    "fuzz": "2%",
    "fill": "white",
    "opaque": "white",
    "colors": 8,
    "dither": "none",
    "replacements": [
      {
        "from": "#278291",
        "to": "#026979"
      },
      {
        "from": "#99BAD1",
        "to": "white"
      },
      {
        "from": "#ABC9D7",
        "to": "white"
      }
    ]
  },
  "vectorizer": {
