    "spliceThreshold": 35,
    "pathPrecision": 6,
    "unusedColorIterations": 16,
    "keyingThreshold": 0.3,
    "smallCircle": 2
  },
  "postprocess": {
    "cleanRibbon": {
      "fill": "#99bad1",
      "path": "M365 496 C520 585 690 620 910 590 C1125 560 1340 482 1578 522 L1578 679 C1430 620 1270 590 1110 588 C1005 587 910 602 805 615 C625 637 485 620 365 650 Z"
